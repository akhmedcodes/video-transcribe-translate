BOT_TOKEN=your_telegram_bot_token_here

# Whisper model size: tiny | base | small | medium | large
# larger = more accurate but slower and uses more RAM
WHISPER_MODEL=base

# Allowed Telegram user IDs (comma-separated).
# If set, only these users can use the bot (private mode).
# If not set or empty, the bot is public (anyone can use it).
# Example: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=
